    "fonts": [
      "Times-Bold",
      "Times-Roman"
    ],
    "sizes": [
      10.0
    ]
  },
  {
    "page_number": 1,
    "bbox": [
      160.65,
      588.67,
      289.37,
      602.01
    ],
