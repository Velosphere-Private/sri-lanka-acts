    ],
    "sizes": [
      10.5,
      11.0
    ]
  },
  {
    "page_number": 3,
    "bbox": [
      54.97,
      79.93,
      274.67,
      103.77
    ],
    "text": "(i) to conduct training courses and workshops for thepurposes of discharging its functions ;",
    "fonts": [
      "*Verdana-8171"
