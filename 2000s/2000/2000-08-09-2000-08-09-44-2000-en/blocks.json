    "bbox": [
      67.34,
      209.04,
      379.41,
      256.04
    ],
    "text": "1. TI1is Act may be cited as the Commercial Mediation Shon 1i1le and Centre of Sri Lanka Act, No. 44 of 2000, and shall come into date of operation. operation on such date as may be appointed by the Minister by Order published in the Gazette.",
    "fonts": [
      "*Arial-Bold-10280",
      "*Minion Pro-10283"
    ],
    "sizes": [
      7.0,
