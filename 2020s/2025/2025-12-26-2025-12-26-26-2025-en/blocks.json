      374.03,
      350.89
    ],
    "text": "(b) the date on which the exemptions",
    "fonts": [
      "TimesNewRomanPS-ItalicMT",
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      10.0
    ]
  },
