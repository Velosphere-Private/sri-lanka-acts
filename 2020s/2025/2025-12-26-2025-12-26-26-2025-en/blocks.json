  },
  {
    "page_number": 7,
    "bbox": [
      184.53,
      205.27,
      374.05,
      302.74
    ],
    "text": "(3) Every regulation made by the Minister, shall within a period of three months after its publication in the Gazette, be brought before Parliament for approval. Any regulation which is not so approved, shall be deemed to be rescinded as from the date of such disapproval, but without prejudice to anything duly done thereunder.",
    "fonts": [
      "TimesNewRomanPS-ItalicMT",
      "TimesNewRomanPSMT"
