  {
    "page_number": 7,
    "bbox": [
      184.53,
      137.27,
      374.05,
      198.74
    ],
    "text": "(2) Every regulation made by the Minister shall be published in the Gazette and shall come into operation on the date of such publication or on such later date as may be specified in such regulation.",
    "fonts": [
      "TimesNewRomanPS-ItalicMT",
      "TimesNewRomanPSMT"
    ],
    "sizes": [
