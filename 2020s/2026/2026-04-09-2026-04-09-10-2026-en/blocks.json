    "fonts": [
      "Times-Italic",
      "Times-Roman"
    ],
    "sizes": [
      10.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      95.0,
      393.16,
      308.05,
      538.83
    ],
