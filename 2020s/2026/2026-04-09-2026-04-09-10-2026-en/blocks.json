      197.7,
      308.03,
      221.63
    ],
    "text": "1. This Act may be cited as the Social Security Contribution Levy (Amendment) Act, No. 10 of 2026.",
    "fonts": [
      "Times-Bold",
      "Times-Roman"
    ],
    "sizes": [
      10.0
